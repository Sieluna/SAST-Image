<Project>
  <PropertyGroup>
    <_RustFsNative_Runtime Condition="'$(RuntimeIdentifier)' == 'win-x64'">win-x64</_RustFsNative_Runtime>
    <_RustFsNative_Runtime Condition="'$(RuntimeIdentifier)' == 'linux-x64'">linux-x64</_RustFsNative_Runtime>
    <_RustFsNative_Runtime Condition="'$(RuntimeIdentifier)' == 'linux-arm64'">linux-arm64</_RustFsNative_Runtime>
    <_RustFsNative_Runtime Condition="'$(RuntimeIdentifier)' == 'osx-x64'">osx-x64</_RustFsNative_Runtime>
    <_RustFsNative_Runtime Condition="'$(RuntimeIdentifier)' == 'osx-arm64'">osx-arm64</_RustFsNative_Runtime>

    <_RustFsNative_Runtime Condition="'$(_RustFsNative_Runtime)' == '' And '$(_RustFsNative_IsWindows)' == 'true'">win-x64</_RustFsNative_Runtime>
    <_RustFsNative_Runtime Condition="'$(_RustFsNative_Runtime)' == '' And '$(_RustFsNative_IsLinux)' == 'true'">linux-x64</_RustFsNative_Runtime>
    <_RustFsNative_Runtime Condition="'$(_RustFsNative_Runtime)' == '' And '$(_RustFsNative_IsMacOS)' == 'true'">osx-x64</_RustFsNative_Runtime>
  </PropertyGroup>

  <ItemGroup Condition="'$(_RustFsNative_Runtime)' != ''">
    <Content Include="$(MSBuildThisFileDirectory)..\runtimes\$(_RustFsNative_Runtime)\native\**"
             Link="runtimes\$(_RustFsNative_Runtime)\native\%(RecursiveDir)%(Filename)%(Extension)"
             CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
